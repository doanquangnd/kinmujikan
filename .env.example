# Neon Postgres - tự động khi thêm Postgres trong Vercel Dashboard
# POSTGRES_URL=
# DATABASE_URL=

# JWT - bắt buộc đổi trong production (vd: openssl rand -base64 32)
# JWT_SECRET=

# Cloudflare Turnstile (captcha). Để trống = không load script.
# Test keys (dùng CẢ HAI cùng lúc, không trộn test với production):
#   Site: 1x00000000000000000000AA  Secret: 1x0000000000000000000000000000000AA
# Trên localhost: mặc định bỏ qua widget (server vẫn bypass). Để test widget:
#   VITE_TURNSTILE_TEST_LOCAL=true  (chạy cửa sổ ẩn danh, tắt extension để tránh lỗi sandbox)
# VITE_TURNSTILE_SITE_KEY=
# TURNSTILE_SECRET_KEY=
# VITE_TURNSTILE_TEST_LOCAL=

# CORS - danh sách origin được phép (phân cách bằng dấu phẩy)
# CORS_ALLOWED_ORIGINS=https://kinmujikan.vercel.app,http://localhost:5173

# Cron - bắt buộc cho Vercel Cron Jobs (tối thiểu 16 ký tự)
# Vercel gửi Bearer token trong header. Dùng: openssl rand -hex 16
# CRON_SECRET=
