# Môi trường: production khi deploy, development chỉ để debug
APP_ENV=production

# MySQL
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=kinmu_jikan
DB_USER=root
DB_PASS=

# JWT: bắt buộc đổi thành chuỗi bí mật dài, ngẫu nhiên (vd: openssl rand -base64 32)
JWT_SECRET=thay_bang_chuoi_bi_mat_dai_va_ngau_nhien

# CORS: bật/tắt giới hạn origin. 0 hoặc để trống = cho phép mọi domain (*). 1 = chỉ chấp nhận origin trong CORS_ORIGINS.
CORS_RESTRICT_ORIGIN=0
# CORS_ORIGINS: danh sách origin được phép khi CORS_RESTRICT_ORIGIN=1 (phân tách bằng dấu phẩy, không slash cuối)
# Ví dụ: http://localhost:5174,https://kinmujikan.vercel.app
# CORS_ORIGINS=http://localhost:5174

# Cloudflare Turnstile (đăng nhập/đăng ký). Để trống = tắt verify
# TURNSTILE_SECRET=
