# Apache: gửi mọi request (kể cả OPTIONS) đến index.php (trừ file tồn tại).
# Preflight OPTIONS phải tới PHP thì mới có header Access-Control-Allow-Origin.
<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteRule ^(.*)$ index.php?path=/$1 [L,QSA]
</IfModule>
