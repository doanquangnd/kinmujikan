# InfinityFree: document root là htdocs, entry point API trong public/index.php.
# Dự phòng CORS: một số host có thể không chuyển OPTIONS tới PHP, set header ở Apache.
<IfModule mod_headers.c>
    SetEnvIf Request_URI "^/api" API_REQUEST
    Header always set Access-Control-Allow-Origin "*" env=API_REQUEST
    Header always set Access-Control-Allow-Methods "GET, POST, PUT, OPTIONS" env=API_REQUEST
    Header always set Access-Control-Allow-Headers "Content-Type, Authorization" env=API_REQUEST
</IfModule>

<IfModule mod_rewrite.c>
    RewriteEngine On

    # 1) Nếu file/thư mục tồn tại trong /public thì phục vụ trực tiếp
    RewriteCond %{DOCUMENT_ROOT}/public%{REQUEST_URI} -f [OR]
    RewriteCond %{DOCUMENT_ROOT}/public%{REQUEST_URI} -d
    RewriteRule ^(.*)$ public/$1 [L]

    # 2) Nếu tồn tại thật trong htdocs thì giữ nguyên
    RewriteCond %{REQUEST_FILENAME} -f [OR]
    RewriteCond %{REQUEST_FILENAME} -d
    RewriteRule ^ - [L]

    # 3) Còn lại: vào public/index.php
    RewriteRule ^ public/index.php [L,QSA]
</IfModule>
