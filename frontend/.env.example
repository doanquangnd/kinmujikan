# Base URL của backend API (tùy chọn).
# VITE_API_URL=  -> request /api qua proxy. VITE_API_URL=http://localhost:8000 -> gọi backend trực tiếp (CORS).

# Proxy target khi backend chạy trong Docker/container (Vite chạy trên host).
# Mặc định proxy tới http://127.0.0.1:8000. Nếu ECONNREFUSED: đảm bảo container publish port 8000 ra host,
# hoặc thử VITE_PROXY_TARGET=http://localhost:8000 (một số môi trường phân giải khác 127.0.0.1).
# VITE_PROXY_TARGET=http://127.0.0.1:8000
