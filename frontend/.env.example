# Base URL của backend API (tùy chọn).
# Để trống: request /api đi qua proxy (Vite dev hoặc Vercel rewrite -> backend). Không set khi deploy Vercel.
# VITE_API_URL=http://localhost:8000 -> gọi backend trực tiếp (CORS).

# Proxy target khi backend chạy trong Docker/container (Vite chạy trên host).
# Mặc định proxy tới http://127.0.0.1:8000. Nếu ECONNREFUSED: đảm bảo container publish port 8000 ra host,
# hoặc thử VITE_PROXY_TARGET=http://localhost:8000 (một số môi trường phân giải khác 127.0.0.1).
# VITE_PROXY_TARGET=http://127.0.0.1:8000

# Cloudflare Turnstile (captcha). Để trống = không load script, không lỗi CSP/110200 khi dev.
# Production: tạo widget tại Cloudflare Dashboard, thêm domain, set VITE_TURNSTILE_SITE_KEY và backend TURNSTILE_SECRET.
# VITE_TURNSTILE_SITE_KEY=
